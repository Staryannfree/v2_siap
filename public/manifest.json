{
  "manifest_version": 3,
  "name": "Planejamento Turbo",
  "description": "Preencha chamadas, valide conteúdos e faça seu planejamento no SIAP de forma rápida, automática e sem estresse.",
  "version": "1.3.0",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_title": "Abrir Planejamento Turbo"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "audioCapture",
    "camera"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "host_permissions": [
    "*://siap.educacao.go.gov.br/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://siap.educacao.go.gov.br/*"],
      "js": ["content.js"]
    }
  ]
}
